{
  "name": "imageproof-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/wasm-bindings --target web --out-dir ../../web/pkg",
    "check": "npm run build:wasm && npm run build",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,css}\" index.html",
    "format:check": "prettier --check \"src/**/*.{js,css}\" index.html"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "vite": "^7.1.5"
  }
}
